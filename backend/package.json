{
  "name": "elo-academico-backend",
  "version": "1.0.0",
  "description": "API do Elo Acadêmico - Plataforma de pesquisa de revistas científicas",
  "main": "dist/server.js",
 "scripts": {
  "dev":"nodemon --exec ts-node src/server.ts",
  "build": "tsc -p tsconfig.build.json",
  "start":"node dist/server.js",
  "seed":"node dist/seeds/createFirstAdmin.js",
  "test":"jest --runInBand --forceExit",
  "test:unit":"jest tests/unit --runInBand --forceExit",
  "test:integration":"jest tests/integration --runInBand --forceExit"
},
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.2",
    "sequelize": "^6.37.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
